// Sifariş modalı aç
function openOrder(id, name, price) {
    selectedProduct = { id, name, price };
    document.getElementById('selectedProductInfo').innerHTML = 
        `✅ Seçilmiş: <b>${name}</b> — <b>${price}</b>`;
    document.getElementById('orderModal')
        .classList.add('show');
}

function closeModal() {
    document.getElementById('orderModal')
        .classList.remove('show');
}

// Sifarişi təsdiqlə
function confirmOrder() {
    const name = document.getElementById('orderName').value;
    const phone = document.getElementById('orderPhone').value;
    const size = document.getElementById('orderSize').value;
    const install = document.getElementById('orderInstall').value;
    const address = document.getElementById('orderAddress').value;
    const note = document.getElementById('orderNote').value;

    if (!name || !phone) {
        alert('⚠️ Ad və telefon daxil edin!');
        return;
    }

    const message = 
        `🛒 YENİ SİFARİŞ — ${SHOP_NAME}\n\n` +
        `📦 Məhsul: ${selectedProduct.name}\n` +
        `💰 Qiymət: ${selectedProduct.price}\n` +
        `📐 Ölçü: ${size || '?'} kv.m\n\n` +
        `👤 Ad: ${name}\n` +
        `📞 Telefon: ${phone}\n` +
        `🔧 Quraşdırma: ${install}\n` +
        `📍 Ünvan: ${address || 'bildirilməyib'}\n` +
        `💬 Qeyd: ${note || 'yoxdur'}`;

    const url = `https://wa.me/${WHATSAPP_NUMBER}` +
        `?text=${encodeURIComponent(message)}`;
    
    window.open(url, '_blank');
    closeModal();
    
    addBotMessage(`
        ✅ <b>Sifarişiniz göndərildi!</b><br><br>
        Tezliklə sizinlə əlaqə saxlayacağıq.<br>
        Təşəkkür edirik! 🙏<br><br>
        <div class="menu-buttons">
            <button class="menu-btn" 
            onclick="backToMenu()">🏠 Ana Menü</button>
        </div>
    `);
}

// Mesaj göndər
function sendMessage() {
    const input = document.getElementById('userInput');
    const text = input.value.trim();
    if (!text) return;
    
    addUserMessage(text);
    input.value = '';
    
    // Açar söz axtarış
    const lower = text.toLowerCase();
    
    if (lower.includes('mdf')) {
        showCategory('mdf');
    } else if (lower.includes('laminat')) {
        showCategory('laminat');
    } else if (lower.includes('3d')) {
        showCategory('3d');
    } else if (lower.includes('divar')) {
        showCategory('divar');
    } else if (lower.includes('qiymət') || 
               lower.includes('price')) {
        showPrices();
    } else if (lower.includes('rəng') || 
               lower.includes('color')) {
        showColors();
    } else if (lower.includes('əlaqə') || 
               lower.includes('telefon') ||
               lower.includes('contact')) {
        showContact();
    } else if (lower.includes('salam') || 
               lower.includes('hello') ||
               lower.includes('hi')) {
        backToMenu();
    } else {
        addBotMessage(`
            Başa düşmədim 😊<br>
            Aşağıdakılardan birini seçin:
            <div class="menu-buttons" 
            style="margin-top:10px">
                <button class="menu-btn" 
                onclick="showCategory('mdf')">
                🪵 MDF</button>
                <button class="menu-btn" 
                onclick="showPrices()">
                💰 Qiymətlər</button>
                <button class="menu-btn" 
                onclick="showContact()">
                📞 Əlaqə</button>
            </div>
        `);
    }
}

function handleKeyPress(e) {
    if (e.key === 'Enter') sendMessage();
}
